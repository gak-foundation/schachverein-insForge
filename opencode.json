{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-froggy",
    "opencode-ignore",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "mcp": {
    "insforge": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@insforge/mcp@latest"
      ],
      "environment": {
        "API_KEY": "ik_f36d4fac6d7aca95be2be8ff361be86e",
        "API_BASE_URL": "https://4d3rbpyx.eu-central.insforge.app"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ]
    },
    "github": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PAT}"
      },
      "enabled": false
    },
    "vercel": {
      "type": "remote",
      "url": "https://mcp.vercel.com"
    }
  }
}