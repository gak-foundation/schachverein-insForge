# Umgebungsvariablen für Schachverein-Plattform
# INSFORGE (Backend-as-a-Service)

# =============================================================================
# InsForge Konfiguration
# =============================================================================
NEXT_PUBLIC_INSFORGE_URL=https://4d3rbpyx.eu-central.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=
INSFORGE_SERVICE_ROLE_KEY=

# =============================================================================
# Anwendungs-URLs
# =============================================================================
NEXT_PUBLIC_ROOT_DOMAIN=schach.studio
NEXT_PUBLIC_APP_DOMAIN=schach.studio
NEXT_PUBLIC_COOKIE_DOMAIN=.schach.studio
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000

# =============================================================================
# E-Mail (Resend) - für Kontaktformular und Benachrichtigungen
# =============================================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=kontakt@schach.studio
CONTACT_NOTIFICATION_EMAIL=kontakt@schach.studio

# =============================================================================
# Sicherheit
# =============================================================================
# Verschlüsselungsschlüssel für sensible Daten (IBAN, etc.)
# Erzeugen mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND_HEX_32

# Cloudflare Turnstile (Captcha)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Super Admin E-Mails (kommagetrennt)
SUPER_ADMIN_EMAILS=

# =============================================================================
# E-Mail (SMTP - für Auth-E-Mails)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@schachverein.example.com

# =============================================================================
# OAuth Provider (optional)
# =============================================================================
# GitHub OAuth
GITHUB_ID=
GITHUB_SECRET=

# Google OAuth
GOOGLE_ID=
GOOGLE_SECRET=

# Lichess OAuth
LICHESS_CLIENT_ID=
LICHESS_CLIENT_SECRET=

# =============================================================================
# KI-Features (Vercel AI SDK - optional)
# =============================================================================
OPENAI_API_KEY=sk-[your-openai-key]

# =============================================================================
# Chess APIs (optional)
# =============================================================================
LICHESS_API_TOKEN=
CHESSCOM_API_TOKEN=

# =============================================================================
# Payment (Mollie)
# =============================================================================
MOLLIE_API_KEY=

# =============================================================================
# Monitoring
# =============================================================================
SENTRY_DSN=

# =============================================================================
# Redis (optional - nur für lokale Entwicklung mit BullMQ)
# =============================================================================
# REDIS_PASSWORD=schachverein
# REDIS_URL=redis://default:schachverein@localhost:6379
