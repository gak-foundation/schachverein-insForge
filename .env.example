# Umgebungsvariablen für Schachverein-Plattform
# VEREINFACHT: Supabase Cloud + PostgreSQL (kein Redis, kein Better Auth, kein MinIO)

# =============================================================================
# Datenbank (Drizzle ORM)
# =============================================================================
# Lokale Entwicklung
DATABASE_URL=postgresql://schachverein:local_dev_password@localhost:5432/schachverein

# Produktion (Supabase PostgreSQL Connection String)
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# =============================================================================
# Supabase Cloud Konfiguration
# Erstelle Projekt auf: https://supabase.com
# Region wählen: EU (Frankfurt) für DSGVO-Konformität
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[your-anon-key]
SUPABASE_SERVICE_ROLE_KEY=[your-service-role-key]

# =============================================================================
# Anwendungs-URLs
# =============================================================================
NEXT_PUBLIC_ROOT_DOMAIN=schach.studio
NEXT_PUBLIC_COOKIE_DOMAIN=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Sicherheit
# =============================================================================
# Verschlüsselungsschlüssel für sensible Daten (IBAN, etc.)
# Erzeugen mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND_HEX_32

# =============================================================================
# E-Mail (für Supabase Auth)
# Supabase sendet E-Mails für Verifizierung und Passwort-Reset
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@schachverein.example.com

# =============================================================================
# OAuth Provider (optional)
# =============================================================================
# GitHub OAuth
GITHUB_ID=
GITHUB_SECRET=

# Lichess OAuth
LICHESS_CLIENT_ID=
LICHESS_CLIENT_SECRET=

# =============================================================================
# KI-Features (Vercel AI SDK - optional)
# =============================================================================
# OpenAI API Key für KI-Features (Turnierberichte, Spielanalyse, Chatbot)
OPENAI_API_KEY=sk-[your-openai-key]

# =============================================================================
# Chess APIs (optional)
# =============================================================================
LICHESS_API_TOKEN=
CHESSCOM_API_TOKEN=

# =============================================================================
# Payment (Mollie)
# =============================================================================
MOLLIE_API_KEY=

# =============================================================================
# Monitoring
# =============================================================================
SENTRY_DSN=

# =============================================================================
# ENTFERNTE VARIABLEN (nicht mehr benötigt)
# =============================================================================
# Diese wurden durch Supabase ersetzt oder entfernt:
#
# ❌ BETTER_AUTH_SECRET - ersetzt durch Supabase Auth
# ❌ BETTER_AUTH_URL - ersetzt durch Supabase Auth
# ❌ REDIS_URL - nicht mehr benötigt (kein BullMQ mehr)
# ❌ REDIS_PASSWORD - nicht mehr benötigt
# ❌ S3_ENDPOINT - ersetzt durch Supabase Storage
# ❌ S3_ACCESS_KEY - ersetzt durch Supabase Storage
# ❌ S3_SECRET_KEY - ersetzt durch Supabase Storage
# ❌ S3_BUCKET - ersetzt durch Supabase Storage
# ❌ RATE_LIMIT_* - ersetzt durch Supabase Auth/Edge Functions
