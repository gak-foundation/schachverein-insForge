# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://schachverein:schachverein@localhost:5432/schachverein

# ─── Better Auth ────────────────────────────────────────────
# Generate a secure random string using: openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND_BASE64_32
BETTER_AUTH_URL=http://admin.localhost:3000

# ─── Domain Configuration ───────────────────────────────────
NEXT_PUBLIC_ROOT_DOMAIN=schach.studio
NEXT_PUBLIC_COOKIE_DOMAIN=
NEXT_PUBLIC_APP_URL=http://admin.localhost:3000

# ─── Encryption ───────────────────────────────────────────────
# Generate a 32-byte hex key using: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND_HEX_32

# GitHub OAuth (optional, for social login)
GITHUB_ID=
GITHUB_SECRET=

# Lichess OAuth (optional)
LICHESS_CLIENT_ID=
LICHESS_CLIENT_SECRET=

# ─── Redis (BullMQ + Rate Limiting) ───────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Rate Limiting ────────────────────────────────────────────
# Login attempts per window (default: 5 per 15 min)
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_WINDOW_MS=900000

# ─── Email (Brevo/Mailjet) ────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@schachverein.example.com

# ─── Storage (S3-compatible) ─────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=schachverein

# ─── Chess APIs (optional) ───────────────────────────────────
LICHESS_API_TOKEN=
CHESSCOM_API_TOKEN=

# ─── Payment (Mollie) ────────────────────────────────────────
MOLLIE_API_KEY=

# ─── Monitoring ──────────────────────────────────────────────
SENTRY_DSN=

# ─── Application Settings ────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
