# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://schachverein:schachverein@localhost:5432/schachverein

# ─── Auth (NextAuth v5) ──────────────────────────────────────
AUTH_SECRET=change-me-to-a-random-secret-in-production
AUTH_URL=http://localhost:3000

# GitHub OAuth (optional, for social login)
GITHUB_ID=
GITHUB_SECRET=

# Lichess OAuth (optional)
LICHESS_CLIENT_ID=
LICHESS_CLIENT_SECRET=

# ─── Redis (BullMQ) ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Email (Brevo/Mailjet) ────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@schachverein.example.com

# ─── Storage (S3-compatible) ─────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=schachverein

# ─── Chess APIs (optional) ───────────────────────────────────
LICHESS_API_TOKEN=
CHESSCOM_API_TOKEN=

# ─── Payment (Mollie) ────────────────────────────────────────
MOLLIE_API_KEY=

# ─── Monitoring ──────────────────────────────────────────────
SENTRY_DSN=