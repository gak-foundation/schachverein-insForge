# Umgebungsvariablen für Schachverein-Plattform
# VEREINFACHT: Supabase Cloud (PostgreSQL + Auth + Storage)

# =============================================================================
# Datenbank (Drizzle ORM)
# =============================================================================
# Supabase PostgreSQL Connection Strings
# Erstelle Projekt auf: https://supabase.com
# Region wählen: EU (Frankfurt) für DSGVO-Konformität
#
# DATABASE_URL (mit Connection Pooling, Port 6543) - für die App/Next.js
DATABASE_URL=postgresql://postgres.projectref:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# DIRECT_URL (ohne Pooling, Port 5432) - für Drizzle Migrationen
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# =============================================================================
# Supabase Cloud Konfiguration
# Erstelle Projekt auf: https://supabase.com
# Region wählen: EU (Frankfurt) für DSGVO-Konformität
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[your-anon-key]
SUPABASE_SERVICE_ROLE_KEY=[your-service-role-key]

# =============================================================================
# Anwendungs-URLs
# =============================================================================
NEXT_PUBLIC_ROOT_DOMAIN=schach.studio
NEXT_PUBLIC_APP_DOMAIN=app.schach.studio
NEXT_PUBLIC_COOKIE_DOMAIN=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# E-Mail (Resend) - für Kontaktformular und Benachrichtigungen
# Erstelle Account auf: https://resend.com
# =============================================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=kontakt@schach.studio
CONTACT_NOTIFICATION_EMAIL=kontakt@schach.studio

# =============================================================================
# Sicherheit
# =============================================================================
# Verschlüsselungsschlüssel für sensible Daten (IBAN, etc.)
# Erzeugen mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND_HEX_32

# Cloudflare Turnstile (Captcha)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# =============================================================================
# E-Mail (für Supabase Auth)
# Supabase sendet E-Mails für Verifizierung und Passwort-Reset
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@schachverein.example.com

# =============================================================================
# OAuth Provider (optional)
# =============================================================================
# GitHub OAuth
GITHUB_ID=
GITHUB_SECRET=

# Lichess OAuth
LICHESS_CLIENT_ID=
LICHESS_CLIENT_SECRET=

# =============================================================================
# KI-Features (Vercel AI SDK - optional)
# =============================================================================
# OpenAI API Key für KI-Features (Turnierberichte, Spielanalyse, Chatbot)
OPENAI_API_KEY=sk-[your-openai-key]

# =============================================================================
# Chess APIs (optional)
# =============================================================================
LICHESS_API_TOKEN=
CHESSCOM_API_TOKEN=

# =============================================================================
# Payment (Mollie)
# =============================================================================
MOLLIE_API_KEY=

# =============================================================================
# Monitoring
# =============================================================================
SENTRY_DSN=

# =============================================================================
# Redis (optional - nur für lokale Entwicklung mit BullMQ)
# =============================================================================
# Wenn Background Jobs via Docker getestet werden:
# REDIS_PASSWORD=schachverein
# REDIS_URL=redis://default:schachverein@localhost:6379

# =============================================================================
# ENTFERNTE VARIABLEN (nicht mehr benötigt)
# =============================================================================
# Diese wurden durch Supabase ersetzt oder entfernt:
#
# ❌ BETTER_AUTH_SECRET - ersetzt durch Supabase Auth
# ❌ BETTER_AUTH_URL - ersetzt durch Supabase Auth
# ❌ S3_ENDPOINT - ersetzt durch Supabase Storage
# ❌ S3_ACCESS_KEY - ersetzt durch Supabase Storage
# ❌ S3_SECRET_KEY - ersetzt durch Supabase Storage
# ❌ S3_BUCKET - ersetzt durch Supabase Storage
# ❌ RATE_LIMIT_* - ersetzt durch Supabase Auth/Edge Functions
